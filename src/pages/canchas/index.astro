---
import Layout from '../../layouts/Layout.astro';
import type { ICourt, ApiResponse } from '../../types';

let courts: ICourt[] = [];
let error = '';

try {
  const response = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/courts`);
  const json: ApiResponse<ICourt[]> = await response.json();
  if (json.success && json.data) {
    courts = json.data;
  }
} catch {
  error = 'No se pudieron cargar las canchas. Intenta de nuevo más tarde.';
}

const minPrice = courts.length ? Math.min(...courts.map((c) => c.pricePerHour)) : 0;
---

<Layout title="Canchas disponibles" description="Encuentra y reserva tu cancha deportiva favorita">

  <!-- ── HEADER ─────────────────────────────────────────────── -->
  <section
    class="relative bg-mk-dark text-mk-cream overflow-hidden"
    style="padding: 48px 48px 52px; border-bottom: 4px solid #0FCB46"
  >
    <!-- Field lines -->
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: linear-gradient(0deg, rgba(15,203,70,.06) 1px, transparent 1px); background-size: 100% 80px"
    ></div>

    <div class="relative max-w-7xl mx-auto">
      <div class="header-content flex flex-col gap-3 max-w-2xl">
        <span
          class="inline-flex items-center gap-2"
          style="font: 600 11px/1 'JetBrains Mono', monospace; letter-spacing: .15em; text-transform: uppercase; color: #0FCB46"
        >
          <span class="inline-block w-4" style="height: 1.5px; background: #0FCB46"></span>
          01 · Encuentra tu cancha
        </span>
        <h1 style="margin: 0; font: 800 clamp(40px, 6vw, 72px)/0.92 'Archivo', system-ui; letter-spacing: -.03em">
          Filtra. Elige. <span style="color: #0FCB46">Reserva.</span>
        </h1>
        <p style="margin: 0; font: 400 16px/1.5 'Inter', sans-serif; color: rgba(244,245,240,.7)">
          {courts.length > 0
            ? `${courts.length} canchas disponibles${minPrice > 0 ? ` · desde S/ ${minPrice}/h` : ''}`
            : 'Reserva la cancha perfecta en Lima.'}
        </p>
      </div>
    </div>
  </section>

  <!-- ── FILTER BAR ──────────────────────────────────────────── -->
  {courts.length > 0 && (
    <section class="sticky top-16 z-30 bg-mk-dark" style="border-bottom: 2px solid #0FCB46">
      <div class="max-w-7xl mx-auto px-4 sm:px-8 lg:px-12 py-3 flex flex-col md:flex-row gap-3 md:items-center">
        <!-- Search input -->
        <div
          class="relative flex-1 flex items-center"
          style="background: rgba(244,245,240,.07); border: 1.5px solid rgba(244,245,240,.18)"
        >
          <span class="pl-3 pr-2 text-mk-green" style="font: 600 10px/1 'JetBrains Mono', monospace; letter-spacing: .1em">▮</span>
          <input
            id="courtSearch"
            type="text"
            placeholder="Nombre, zona o tipo de cancha..."
            class="flex-1 h-10 pr-4 bg-transparent outline-none text-mk-cream placeholder-mk-cream/40"
            style="font: 500 14px/1 'Inter', sans-serif"
          />
        </div>
        <!-- Sort chips -->
        <div class="flex items-center gap-2 overflow-x-auto no-scrollbar">
          <span
            class="shrink-0"
            style="font: 600 10px/1 'JetBrains Mono', monospace; letter-spacing: .12em; text-transform: uppercase; color: rgba(244,245,240,.4); white-space: nowrap"
          >
            Orden:
          </span>
          <button data-sort="default" class="sort-chip sort-active shrink-0">Todas</button>
          <button data-sort="price"   class="sort-chip shrink-0">Menor precio</button>
          <button data-sort="slots"   class="sort-chip shrink-0">Más turnos</button>
        </div>
      </div>
    </section>
  )}

  <!-- ── GRID ───────────────────────────────────────────────── -->
  <section class="bg-mk-cream" style="padding: 48px 48px 80px">
    <div class="max-w-7xl mx-auto">

      {error && (
        <div
          class="mb-8 p-4 flex items-center gap-3"
          style="background: rgba(255,50,50,.08); border-left: 4px solid #ff4040; border-top: 1px solid rgba(255,80,80,.3); border-bottom: 1px solid rgba(255,80,80,.3); border-right: 1px solid rgba(255,80,80,.3)"
        >
          <span style="font: 700 13px/1.4 'Inter', sans-serif; color: #0A0E0B">{error}</span>
        </div>
      )}

      {courts.length === 0 && !error && (
        <div class="text-center" style="padding: 80px 20px">
          <div style="font: 900 40px/1 'Archivo', system-ui; color: #0A0E0B; margin-bottom: 12px">Sin canchas aún.</div>
          <p style="font: 400 14px/1.5 'Inter', sans-serif; color: rgba(10,14,11,.6); max-width: 400px; margin: 0 auto 24px">
            Estamos preparando nuevas canchas. Vuelve pronto.
          </p>
          <a
            href="/"
            style="display: inline-flex; align-items: center; gap: 8px; background: #0A0E0B; color: #F4F5F0; border: 2px solid #0A0E0B; padding: 12px 20px; font: 700 12px/1 'Inter', sans-serif; letter-spacing: .02em; text-transform: uppercase; box-shadow: 4px 4px 0 #0FCB46; text-decoration: none"
          >
            ← Volver al inicio
          </a>
        </div>
      )}

      {courts.length > 0 && (
        <div class="flex items-center justify-between mb-8">
          <span style="font: 600 11px/1 'JetBrains Mono', monospace; letter-spacing: .15em; text-transform: uppercase; color: rgba(10,14,11,.6)">
            ▮ <span id="resultCount">{courts.length} {courts.length === 1 ? 'cancha' : 'canchas'}</span> disponibles
          </span>
          <span style="font: 500 12px/1 'Inter', sans-serif; color: rgba(10,14,11,.5)">
            Ordenado por: <strong id="sortLabel" style="color: #0A0E0B">Todas</strong> ↓
          </span>
        </div>
      )}

      <div id="emptySearch" class="hidden text-center" style="padding: 60px 20px">
        <div style="font: 800 28px/1 'Archivo', system-ui; color: #0A0E0B; margin-bottom: 8px">Sin resultados.</div>
        <div style="font: 400 14px/1.5 'Inter', sans-serif; color: rgba(10,14,11,.55)">
          Prueba quitar filtros o cambia de búsqueda.
        </div>
      </div>

      <div id="courtsGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {courts.map((court) => (
          <a
            href={`/canchas/${court._id}`}
            data-name={court.name.toLowerCase()}
            data-location={court.location.toLowerCase()}
            data-price={court.pricePerHour}
            data-slots={court.availableSlots?.length ?? 0}
            class="court-card bg-white flex flex-col transition-all duration-150"
            style="border: 2px solid #0A0E0B; text-decoration: none"
            onmouseenter="this.style.transform='translate(-2px,-2px)';this.style.boxShadow='6px 6px 0 #0FCB46'"
            onmouseleave="this.style.transform='';this.style.boxShadow=''"
          >
            <!-- Image -->
            {court.images?.[0] ? (
              <div class="relative overflow-hidden" style="height: 180px">
                <img
                  src={court.images[0]}
                  alt={court.name}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
                {(court.images?.length ?? 0) > 1 && (
                  <div
                    class="absolute top-2 right-2"
                    style="background: rgba(10,14,11,.75); color: #F4F5F0; padding: 4px 8px; font: 600 10px/1 'JetBrains Mono', monospace; letter-spacing: .08em"
                  >
                    {court.images.length} FOTOS
                  </div>
                )}
              </div>
            ) : (
              <div class="relative overflow-hidden flex items-end" style="height: 180px; background: #0A0E0B">
                <div class="absolute inset-0" style="background: repeating-linear-gradient(135deg, #0A2A14 0 14px, #0D341A 14px 28px)"></div>
                <div class="absolute" style="top: 50%; left: 8%; right: 8%; height: 2px; background: rgba(255,255,255,.18); transform: translateY(-50%)"></div>
                <div class="absolute" style="top: 50%; left: 50%; width: 56px; height: 56px; border: 2px solid rgba(255,255,255,.2); border-radius: 50%; transform: translate(-50%, -50%)"></div>
                <span class="relative z-10 p-3" style="font: 600 9.5px/1 'JetBrains Mono', monospace; letter-spacing: .08em; text-transform: uppercase; color: #0FCB46">▮ LIBRE</span>
              </div>
            )}

            <!-- Content -->
            <div class="flex flex-col gap-3 flex-1" style="padding: 18px">
              <div>
                <div style="font: 600 10px/1 'JetBrains Mono', monospace; letter-spacing: .1em; text-transform: uppercase; color: rgba(10,14,11,.55); margin-bottom: 6px">
                  ◉ {court.location}
                </div>
                <h3 style="margin: 0; font: 800 18px/1.15 'Archivo', system-ui; letter-spacing: -.01em; color: #0A0E0B">
                  {court.name}
                </h3>
              </div>

              {(court.availableSlots?.length ?? 0) > 0 && (
                <div class="flex flex-wrap gap-1.5">
                  {(court.availableSlots ?? []).slice(0, 3).map((slot) => (
                    <span style="display: inline-block; padding: 4px 9px; background: rgba(15,203,70,.1); border: 1px solid rgba(15,203,70,.35); font: 600 11px/1 'JetBrains Mono', monospace; color: #0A0E0B; letter-spacing: .04em">
                      {slot.startTime}–{slot.endTime}
                    </span>
                  ))}
                  {(court.availableSlots?.length ?? 0) > 3 && (
                    <span style="font: 500 11px/1 'Inter', sans-serif; color: rgba(10,14,11,.5); padding: 4px 6px">
                      +{(court.availableSlots?.length ?? 0) - 3} más
                    </span>
                  )}
                </div>
              )}

              <div class="mt-auto flex items-center justify-between" style="padding-top: 14px; border-top: 1px dashed rgba(10,14,11,.2)">
                <div>
                  <div style="font: 600 9px/1 'JetBrains Mono', monospace; letter-spacing: .1em; text-transform: uppercase; color: rgba(10,14,11,.5); margin-bottom: 3px">
                    desde
                  </div>
                  <div style="font: 900 24px/1 'Archivo', system-ui; font-variant-numeric: tabular-nums; color: #0A0E0B">
                    S/{court.pricePerHour}
                    <span style="font: 500 12px/1 'Inter', sans-serif; color: rgba(10,14,11,.55); margin-left: 4px">/h</span>
                  </div>
                </div>
                <span style="font: 700 12px/1 'Inter', sans-serif; color: #0FCB46">Reservar →</span>
              </div>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

</Layout>

<style>
  .header-content {
    animation: fadeUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.1s both;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .sort-chip {
    padding: 8px 14px;
    background: transparent;
    border: 1.5px solid rgba(244,245,240,.2);
    color: rgba(244,245,240,.6);
    font: 600 11px/1 'Inter', sans-serif;
    letter-spacing: .04em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all .15s ease;
    white-space: nowrap;
  }
  .sort-chip:hover {
    border-color: rgba(244,245,240,.5);
    color: #F4F5F0;
  }
  .sort-active {
    background: #0FCB46 !important;
    color: #0A0E0B !important;
    border-color: #0FCB46 !important;
    font-weight: 700;
  }

  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

  ::placeholder { color: rgba(244,245,240,.35); }
</style>

<script>
  const searchInput = document.getElementById('courtSearch') as HTMLInputElement | null;
  const grid = document.getElementById('courtsGrid');
  const resultCountEl = document.getElementById('resultCount');
  const sortLabelEl = document.getElementById('sortLabel');
  const emptySearch = document.getElementById('emptySearch');
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.court-card'));
  const sortButtons = Array.from(document.querySelectorAll<HTMLElement>('[data-sort]'));
  const totalCards = cards.length;
  let activeSort = 'default';

  const sortLabels: Record<string, string> = {
    default: 'Todas',
    price: 'Menor precio',
    slots: 'Más turnos',
  };

  function apply() {
    const q = (searchInput?.value ?? '').trim().toLowerCase();
    const visible = cards.filter((el) => {
      const name = el.dataset.name ?? '';
      const location = el.dataset.location ?? '';
      return !q || name.includes(q) || location.includes(q);
    });

    if (activeSort === 'price') {
      visible.sort((a, b) => Number(a.dataset.price ?? 0) - Number(b.dataset.price ?? 0));
    } else if (activeSort === 'slots') {
      visible.sort((a, b) => Number(b.dataset.slots ?? 0) - Number(a.dataset.slots ?? 0));
    }

    visible.forEach((el) => grid?.appendChild(el));
    cards.forEach((el) => { el.style.display = visible.includes(el) ? '' : 'none'; });

    if (resultCountEl) {
      resultCountEl.textContent =
        visible.length === totalCards
          ? `${totalCards} ${totalCards === 1 ? 'cancha' : 'canchas'}`
          : `${visible.length} de ${totalCards} canchas`;
    }
    if (sortLabelEl) sortLabelEl.textContent = sortLabels[activeSort] ?? 'Todas';
    emptySearch?.classList.toggle('hidden', visible.length > 0);
    grid?.classList.toggle('hidden', visible.length === 0);
  }

  searchInput?.addEventListener('input', apply);
  sortButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeSort = btn.dataset.sort ?? 'default';
      sortButtons.forEach((b) => b.classList.remove('sort-active'));
      btn.classList.add('sort-active');
      apply();
    });
  });
</script>
