---
import Layout from '../../layouts/Layout.astro';
import ReservationForm from '../../components/ReservationForm';
import type { ICourt, ApiResponse } from '../../types';

const { id } = Astro.params;
const API_URL = import.meta.env.PUBLIC_API_URL;
const MAPS_KEY = import.meta.env.PUBLIC_GOOGLE_MAPS_KEY;

let court: ICourt | null = null;
let notFound = false;

try {
  const res = await fetch(`${API_URL}/api/courts/${id}`);
  const json: ApiResponse<ICourt> = await res.json();
  if (json.success && json.data) {
    court = json.data;
  } else {
    notFound = true;
  }
} catch {
  notFound = true;
}

if (notFound || !court) {
  return Astro.redirect('/canchas');
}

const hasMultipleImages = (court.images?.length ?? 0) > 1;
const mapsQuery = (court as any).coordinates
  ? `${(court as any).coordinates.lat},${(court as any).coordinates.lng}`
  : encodeURIComponent(court.location);
const mapsEmbedUrl = MAPS_KEY
  ? `https://www.google.com/maps/embed/v1/place?key=${MAPS_KEY}&q=${mapsQuery}&zoom=16`
  : null;
const mapsLink = `https://www.google.com/maps/search/?api=1&query=${mapsQuery}`;
---

<Layout title={court.name} description={`Reserva ${court.name} en ${court.location}`}>

  <!-- ═══════════════════════════════════════════════════════
       HERO: Galería de imágenes
  ═══════════════════════════════════════════════════════ -->
  <div class="relative bg-gray-900 overflow-hidden h-64 sm:h-80 md:h-96 lg:h-[480px]" id="gallery">
    {court.images && court.images.length > 0 ? (
      <>
        {/* Slides */}
        {court.images.map((img, i) => (
          <div
            class="gallery-slide absolute inset-0 transition-opacity duration-500"
            style={`opacity: ${i === 0 ? '1' : '0'}; z-index: ${i === 0 ? '1' : '0'};`}
            data-index={i}
          >
            <img
              src={img}
              alt={`${court.name} - foto ${i + 1}`}
              class="w-full h-full object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-gray-900/70 via-transparent to-transparent" />
          </div>
        ))}

        {/* Indicadores */}
        {hasMultipleImages && (
          <div class="absolute bottom-3 sm:bottom-6 left-1/2 -translate-x-1/2 flex gap-1.5 sm:gap-2 z-10">
            {court.images.map((_, i) => (
              <button
                class="gallery-dot w-1.5 h-1.5 sm:w-2 sm:h-2 rounded-full transition-all bg-white/50 hover:bg-white"
                style={i === 0 ? 'background:white; width:24px;' : ''}
                data-target={i}
                aria-label={`Foto ${i + 1}`}
              />
            ))}
          </div>
        )}

        {/* Flechas */}
        {hasMultipleImages && (
          <>
            <button
              id="gallery-prev"
              class="absolute left-2 sm:left-4 top-1/2 -translate-y-1/2 z-10 w-9 h-9 sm:w-10 sm:h-10 rounded-full bg-black/40 hover:bg-black/70 text-white flex items-center justify-center transition-colors backdrop-blur-sm"
              aria-label="Anterior"
            >‹</button>
            <button
              id="gallery-next"
              class="absolute right-2 sm:right-4 top-1/2 -translate-y-1/2 z-10 w-9 h-9 sm:w-10 sm:h-10 rounded-full bg-black/40 hover:bg-black/70 text-white flex items-center justify-center transition-colors backdrop-blur-sm"
              aria-label="Siguiente"
            >›</button>
          </>
        )}

        {/* Contador */}
        {hasMultipleImages && (
          <div class="absolute top-3 right-3 sm:top-4 sm:right-4 z-10 text-[11px] sm:text-xs text-white/80 bg-black/40 px-2 sm:px-2.5 py-0.5 sm:py-1 rounded-full backdrop-blur-sm">
            <span id="gallery-current">1</span> / {court.images.length}
          </div>
        )}
      </>
    ) : (
      <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-primary-800 to-primary-600">
        <span class="text-9xl opacity-20">⚽</span>
      </div>
    )}

    {/* Breadcrumb sobre la imagen */}
    <nav class="absolute top-3 left-3 sm:top-4 sm:left-4 z-10 flex items-center gap-1.5 sm:gap-2 text-[11px] sm:text-sm text-white/75 bg-black/30 px-2.5 sm:px-3 py-1 sm:py-1.5 rounded-full backdrop-blur-sm">
      <a href="/canchas" class="hover:text-white transition-colors font-medium">Canchas</a>
      <span class="text-white/40">/</span>
      <span class="font-heading text-white font-bold truncate max-w-[140px] sm:max-w-48 tracking-tight">{court.name}</span>
    </nav>
  </div>

  <!-- ═══════════════════════════════════════════════════════
       CONTENIDO PRINCIPAL
  ═══════════════════════════════════════════════════════ -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-10 pb-28 lg:pb-10">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-6 sm:gap-8 lg:gap-10">

      <!-- ── Columna izquierda: info ── -->
      <div class="lg:col-span-3 space-y-6 sm:space-y-8">

        <!-- Encabezado -->
        <div>
          <div class="flex items-start justify-between gap-3 sm:gap-4">
            <div class="min-w-0">
              <h1 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-black text-gray-900 mb-2 leading-[1.05] tracking-tight">{court.name}</h1>
              <a
                href={mapsLink}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-xs sm:text-sm text-gray-500 hover:text-primary-600 transition-colors group"
              >
                <svg class="w-4 h-4 text-red-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                </svg>
                <span class="group-hover:underline">{court.location}</span>
              </a>
            </div>
            <div class="text-right flex-shrink-0">
              <p class="font-heading text-2xl sm:text-3xl font-black text-primary-600 leading-none">S/ {court.pricePerHour}</p>
              <p class="text-xs sm:text-sm text-gray-400 mt-1">por hora</p>
            </div>
          </div>

          {court.description && (
            <p class="mt-4 text-sm sm:text-base text-gray-600 leading-relaxed">{court.description}</p>
          )}
        </div>

        <!-- Horarios disponibles -->
        {(court.availableSlots?.length ?? 0) > 0 && (
          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-4 sm:p-6">
            <h2 class="font-heading font-black text-gray-900 mb-4 flex items-center gap-2 text-base sm:text-lg">
              <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              Turnos disponibles
            </h2>

            <div class="space-y-2">
              {court.availableSlots.map((slot) => {
                const [sh, sm] = slot.startTime.split(':').map(Number);
                const [eh, em] = slot.endTime.split(':').map(Number);
                const mins = (eh * 60 + em) - (sh * 60 + sm);
                const durLabel = mins > 0
                  ? `${Math.floor(mins/60)}h${mins%60>0 ? ` ${mins%60}m` : ''}`
                  : '';
                return (
                  <div class="flex items-center justify-between bg-gray-50 rounded-xl px-4 py-3 hover:bg-primary-50 transition-colors">
                    <div class="flex items-center gap-3">
                      <div class="w-1.5 h-1.5 rounded-full bg-primary-500" />
                      <span class="font-heading font-bold text-gray-800 text-sm tracking-tight">
                        {slot.startTime} – {slot.endTime}
                      </span>
                    </div>
                    {durLabel && (
                      <span class="text-xs text-gray-400 bg-white border border-gray-100 px-2 py-0.5 rounded-full">
                        {durLabel}
                      </span>
                    )}
                  </div>
                );
              })}
            </div>

            <p class="text-xs text-gray-400 mt-4 flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              Puedes reservar hasta 3 horas continuas. La disponibilidad real se verifica al elegir la fecha.
            </p>
          </div>
        )}

        <!-- Mapa de ubicación -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
          <div class="p-4 sm:p-5 border-b border-gray-50">
            <h2 class="font-heading font-black text-gray-900 flex items-center gap-2 text-base sm:text-lg">
              <svg class="w-5 h-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
              </svg>
              Cómo llegar
            </h2>
          </div>

          {mapsEmbedUrl ? (
            <iframe
              src={mapsEmbedUrl}
              class="w-full h-52 sm:h-64 border-0"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title={`Mapa de ${court.name}`}
            />
          ) : (
            <div class="h-44 sm:h-52 bg-gradient-to-br from-gray-100 to-gray-200 flex flex-col items-center justify-center gap-3">
              <div class="text-4xl">🗺️</div>
              <p class="text-sm text-gray-500 font-medium">{court.location}</p>
            </div>
          )}

          <div class="p-3 sm:p-4 flex items-center justify-between gap-3 bg-gray-50">
            <p class="text-xs sm:text-sm text-gray-600 flex items-center gap-1.5 min-w-0">
              <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span class="truncate">{court.location}</span>
            </p>
            <a
              href={mapsLink}
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs font-semibold text-primary-600 hover:text-primary-700 flex items-center gap-1 transition-colors shrink-0"
            >
              Abrir en Maps
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
          </div>
        </div>

      </div>

      <!-- ── Columna derecha: formulario de reserva ── -->
      <div id="reservar" class="lg:col-span-2 scroll-mt-20">
        <div class="lg:sticky lg:top-6">
          <!-- Card wrapper -->
          <div class="bg-white rounded-2xl border border-gray-100 shadow-lg">
            <div class="relative bg-gradient-to-br from-primary-700 via-primary-600 to-emerald-600 px-4 sm:px-6 py-4 sm:py-5 overflow-hidden rounded-t-2xl">
              <div class="absolute -top-10 -right-10 w-40 h-40 bg-white/10 rounded-full blur-2xl pointer-events-none"></div>
              <p class="relative text-primary-100 text-[11px] sm:text-xs font-semibold uppercase tracking-widest mb-1">Reservar cancha</p>
              <p class="relative font-heading text-white text-2xl sm:text-3xl font-black leading-none">
                S/ {court.pricePerHour}
                <span class="text-primary-100/90 text-sm sm:text-base font-medium tracking-normal">/ hora</span>
              </p>
            </div>
            <div class="p-4 sm:p-6">
              <ReservationForm court={court} apiUrl={API_URL} client:load />
            </div>
          </div>

          <!-- Badges de confianza -->
          <div class="mt-4 grid grid-cols-3 gap-2">
            {[
              { icon: '🔒', label: 'Pago seguro' },
              { icon: '✅', label: 'Confirmación inmediata' },
              { icon: '📱', label: 'QR de acceso' },
            ].map((b) => (
              <div class="bg-white border border-gray-100 rounded-xl p-2.5 sm:p-3 text-center shadow-sm">
                <div class="text-lg sm:text-xl mb-1">{b.icon}</div>
                <p class="text-[10px] sm:text-xs text-gray-500 font-medium leading-tight">{b.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════
       STICKY CTA MÓVIL
  ═══════════════════════════════════════════════════════ -->
  <div class="lg:hidden fixed bottom-0 inset-x-0 z-40 bg-white/95 backdrop-blur-md border-t border-gray-200 shadow-[0_-4px_20px_rgba(0,0,0,0.08)] px-4 py-3 flex items-center justify-between gap-3">
    <div class="min-w-0">
      <p class="text-[11px] text-gray-400 uppercase tracking-widest leading-none font-semibold">Desde</p>
      <p class="font-heading text-xl font-black text-primary-600 leading-tight">S/ {court.pricePerHour} <span class="text-xs text-gray-400 font-medium">/hora</span></p>
    </div>
    <a
      href="#reservar"
      class="font-heading font-black bg-primary-600 hover:bg-primary-700 active:bg-primary-800 text-white px-5 py-3 rounded-xl text-sm whitespace-nowrap transition-colors shadow-sm tracking-tight"
    >
      Reservar ahora →
    </a>
  </div>
</Layout>

<script>
  // ── Galería de imágenes ──
  const slides = document.querySelectorAll<HTMLElement>('.gallery-slide');
  const dots = document.querySelectorAll<HTMLElement>('.gallery-dot');
  const counter = document.getElementById('gallery-current');
  let current = 0;

  function goTo(index: number) {
    slides[current].style.opacity = '0';
    slides[current].style.zIndex = '0';
    dots[current]?.removeAttribute('style');

    current = (index + slides.length) % slides.length;

    slides[current].style.opacity = '1';
    slides[current].style.zIndex = '1';
    if (dots[current]) {
      dots[current].style.cssText = 'background:white; width:24px;';
    }
    if (counter) counter.textContent = String(current + 1);
  }

  document.getElementById('gallery-prev')?.addEventListener('click', () => goTo(current - 1));
  document.getElementById('gallery-next')?.addEventListener('click', () => goTo(current + 1));
  dots.forEach((dot) => {
    dot.addEventListener('click', () => goTo(Number(dot.dataset.target)));
  });

  // Auto-advance each 5s if multiple images
  if (slides.length > 1) {
    setInterval(() => goTo(current + 1), 5000);
  }
</script>
