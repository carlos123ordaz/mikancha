---
import Layout from '../../layouts/Layout.astro';
import ReservationForm from '../../components/ReservationForm';
import type { ICourt, ApiResponse } from '../../types';

const { id } = Astro.params;
const API_URL = import.meta.env.PUBLIC_API_URL;
const MAPS_KEY = import.meta.env.PUBLIC_GOOGLE_MAPS_KEY;

let court: ICourt | null = null;
let notFound = false;

try {
  const res = await fetch(`${API_URL}/api/courts/${id}`);
  const json: ApiResponse<ICourt> = await res.json();
  if (json.success && json.data) {
    court = json.data;
  } else {
    notFound = true;
  }
} catch {
  notFound = true;
}

if (notFound || !court) {
  return Astro.redirect('/canchas');
}

const hasMultipleImages = (court.images?.length ?? 0) > 1;
const mapsQuery = (court as any).coordinates
  ? `${(court as any).coordinates.lat},${(court as any).coordinates.lng}`
  : encodeURIComponent(court.location);
const mapsEmbedUrl = MAPS_KEY
  ? `https://www.google.com/maps/embed/v1/place?key=${MAPS_KEY}&q=${mapsQuery}&zoom=16`
  : null;
const mapsLink = `https://www.google.com/maps/search/?api=1&query=${mapsQuery}`;
---

<Layout title={court.name} description={`Reserva ${court.name} en ${court.location}`}>

  <!-- ── GALERÍA ──────────────────────────────────────────────── -->
  <div class="relative overflow-hidden" id="gallery" style="height: 320px; background: #0A0E0B">
    {court.images && court.images.length > 0 ? (
      <>
        {court.images.map((img, i) => (
          <div
            class="gallery-slide absolute inset-0 transition-opacity duration-500"
            style={`opacity: ${i === 0 ? '1' : '0'}; z-index: ${i === 0 ? '1' : '0'};`}
            data-index={i}
          >
            <img src={img} alt={`${court.name} - foto ${i + 1}`} class="w-full h-full object-cover" />
            <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(10,14,11,.65) 0%, transparent 50%)"></div>
          </div>
        ))}

        {hasMultipleImages && (
          <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 z-10">
            {court.images.map((_, i) => (
              <button
                class="gallery-dot transition-all"
                style={i === 0
                  ? 'width: 24px; height: 4px; background: #0FCB46'
                  : 'width: 8px; height: 4px; background: rgba(244,245,240,.4)'}
                data-target={i}
                aria-label={`Foto ${i + 1}`}
              />
            ))}
          </div>
        )}

        {hasMultipleImages && (
          <>
            <button
              id="gallery-prev"
              class="absolute left-3 top-1/2 -translate-y-1/2 z-10 w-10 h-10 flex items-center justify-center text-mk-cream transition-colors"
              style="background: rgba(10,14,11,.6); border: 1.5px solid rgba(244,245,240,.2); font-size: 18px"
              aria-label="Anterior"
            >‹</button>
            <button
              id="gallery-next"
              class="absolute right-3 top-1/2 -translate-y-1/2 z-10 w-10 h-10 flex items-center justify-center text-mk-cream transition-colors"
              style="background: rgba(10,14,11,.6); border: 1.5px solid rgba(244,245,240,.2); font-size: 18px"
              aria-label="Siguiente"
            >›</button>
          </>
        )}

        {hasMultipleImages && (
          <div
            class="absolute top-3 right-3 z-10"
            style="background: rgba(10,14,11,.7); color: rgba(244,245,240,.8); padding: 5px 10px; font: 600 10px/1 'JetBrains Mono', monospace; letter-spacing: .08em"
          >
            <span id="gallery-current">1</span> / {court.images.length}
          </div>
        )}
      </>
    ) : (
      <div class="w-full h-full flex items-end justify-start" style="background: #0A0E0B; position: relative">
        <div class="absolute inset-0" style="background: repeating-linear-gradient(135deg, #0A2A14 0 20px, #0D341A 20px 40px)"></div>
        <div class="absolute" style="top: 50%; left: 10%; right: 10%; height: 2px; background: rgba(255,255,255,.15); transform: translateY(-50%)"></div>
        <div class="absolute" style="top: 50%; left: 50%; width: 80px; height: 80px; border: 2px solid rgba(255,255,255,.18); border-radius: 50%; transform: translate(-50%, -50%)"></div>
        <span class="relative z-10 p-4" style="font: 600 10px/1 'JetBrains Mono', monospace; letter-spacing: .1em; text-transform: uppercase; color: #0FCB46">▮ CANCHA DISPONIBLE</span>
      </div>
    )}

    <!-- Breadcrumb -->
    <nav
      class="absolute top-3 left-3 z-10 flex items-center gap-2"
      style="background: rgba(10,14,11,.75); padding: 6px 12px; border: 1px solid rgba(244,245,240,.15)"
    >
      <a
        href="/canchas"
        class="hover:text-mk-cream transition-colors"
        style="font: 600 10px/1 'JetBrains Mono', monospace; letter-spacing: .12em; text-transform: uppercase; color: rgba(244,245,240,.6); text-decoration: none"
      >
        Canchas
      </a>
      <span style="color: rgba(244,245,240,.3); font-size: 10px">/</span>
      <span
        style="font: 700 10px/1 'JetBrains Mono', monospace; letter-spacing: .12em; text-transform: uppercase; color: #0FCB46; max-width: 180px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis"
      >
        {court.name}
      </span>
    </nav>
  </div>

  <!-- ── CONTENIDO PRINCIPAL ──────────────────────────────────── -->
  <div class="bg-mk-cream" style="padding-bottom: 80px">
    <div class="max-w-7xl mx-auto px-4 sm:px-8 lg:px-12 pt-8 pb-28 lg:pb-10">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-6 lg:gap-10">

        <!-- ── Columna izquierda: info ── -->
        <div class="lg:col-span-3 flex flex-col gap-5">

          <!-- Encabezado -->
          <div class="bg-white flex flex-col gap-4" style="border: 2px solid #0A0E0B; padding: 24px">
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0">
                <div style="font: 600 10px/1 'JetBrains Mono', monospace; letter-spacing: .12em; text-transform: uppercase; color: rgba(10,14,11,.5); margin-bottom: 8px">
                  ◉ {court.location}
                </div>
                <h1 style="margin: 0; font: 900 clamp(28px, 4vw, 44px)/1 'Archivo', system-ui; letter-spacing: -.025em; color: #0A0E0B">
                  {court.name}
                </h1>
                <a
                  href={mapsLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 mt-2 hover:opacity-70 transition-opacity"
                  style="font: 500 12px/1 'Inter', sans-serif; color: rgba(10,14,11,.55); text-decoration: none"
                >
                  <svg class="w-3.5 h-3.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                  </svg>
                  {court.location} · Ver en Maps ↗
                </a>
              </div>
              <div class="text-right shrink-0">
                <div style="font: 600 9px/1 'JetBrains Mono', monospace; letter-spacing: .1em; text-transform: uppercase; color: rgba(10,14,11,.5); margin-bottom: 4px">
                  desde
                </div>
                <div style="font: 900 36px/1 'Archivo', system-ui; color: #0FCB46; font-variant-numeric: tabular-nums">
                  S/{court.pricePerHour}
                  <span style="font: 500 14px/1 'Inter', sans-serif; color: rgba(10,14,11,.5)">/h</span>
                </div>
              </div>
            </div>

            {court.description && (
              <div
                class="court-description"
                set:html={court.description}
                style="font: 400 14px/1.6 'Inter', sans-serif; color: rgba(10,14,11,.7); padding-top: 14px; border-top: 1px dashed rgba(10,14,11,.2)"
              />
            )}
          </div>

          <!-- Turnos disponibles -->
          {(court.availableSlots?.length ?? 0) > 0 && (
            <div class="bg-white flex flex-col" style="border: 2px solid #0A0E0B">
              <div style="padding: 14px 20px; border-bottom: 2px solid #0A0E0B; background: #0A0E0B">
                <span style="font: 600 10px/1 'JetBrains Mono', monospace; letter-spacing: .15em; text-transform: uppercase; color: #0FCB46">
                  ▮ Turnos disponibles
                </span>
              </div>
              <div class="flex flex-col" style="padding: 12px 0">
                {court.availableSlots.map((slot, i) => {
                  const [sh, sm] = slot.startTime.split(':').map(Number);
                  const [eh, em] = slot.endTime.split(':').map(Number);
                  const mins = (eh * 60 + em) - (sh * 60 + sm);
                  const durLabel = mins > 0
                    ? `${Math.floor(mins/60)}h${mins%60>0 ? ` ${mins%60}m` : ''}`
                    : '';
                  return (
                    <div
                      class="flex items-center justify-between"
                      style={`padding: 10px 20px; border-left: 3px solid #0FCB46; margin: 2px 12px${i < court.availableSlots.length - 1 ? '; border-bottom: 1px solid rgba(10,14,11,.08)' : ''}`}
                    >
                      <div class="flex items-center gap-3">
                        <div style="width: 6px; height: 6px; background: #0FCB46; border-radius: 50%; flex-shrink: 0"></div>
                        <span style="font: 700 15px/1 'Archivo', system-ui; letter-spacing: -.01em; color: #0A0E0B">
                          {slot.startTime} – {slot.endTime}
                        </span>
                      </div>
                      {durLabel && (
                        <span style="font: 600 10px/1 'JetBrains Mono', monospace; letter-spacing: .08em; color: rgba(10,14,11,.45); text-transform: uppercase">
                          {durLabel}
                        </span>
                      )}
                    </div>
                  );
                })}
              </div>
              <div style="padding: 10px 20px; border-top: 1px solid rgba(10,14,11,.1); font: 400 11px/1.5 'Inter', sans-serif; color: rgba(10,14,11,.45)">
                La disponibilidad real se verifica al elegir la fecha.
              </div>
            </div>
          )}

          <!-- Mapa -->
          <div class="bg-white overflow-hidden" style="border: 2px solid #0A0E0B">
            <div style="padding: 14px 20px; border-bottom: 2px solid #0A0E0B; background: #0A0E0B">
              <span style="font: 600 10px/1 'JetBrains Mono', monospace; letter-spacing: .15em; text-transform: uppercase; color: #0FCB46">
                ▮ Cómo llegar
              </span>
            </div>

            {mapsEmbedUrl ? (
              <iframe
                src={mapsEmbedUrl}
                class="w-full border-0"
                style="height: 240px; display: block"
                allowfullscreen
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title={`Mapa de ${court.name}`}
              />
            ) : (
              <div class="flex flex-col items-center justify-center gap-3" style="height: 180px; background: #F4F5F0">
                <div style="font: 700 13px/1 'Inter', sans-serif; color: rgba(10,14,11,.5)">{court.location}</div>
              </div>
            )}

            <div
              class="flex items-center justify-between gap-3"
              style="padding: 12px 20px; border-top: 1px solid rgba(10,14,11,.1)"
            >
              <span style="font: 500 12px/1 'Inter', sans-serif; color: rgba(10,14,11,.55); min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap">
                {court.location}
              </span>
              <a
                href={mapsLink}
                target="_blank"
                rel="noopener noreferrer"
                class="shrink-0"
                style="font: 700 11px/1 'JetBrains Mono', monospace; letter-spacing: .08em; text-transform: uppercase; color: #0FCB46; text-decoration: none"
              >
                Abrir en Maps ↗
              </a>
            </div>
          </div>

        </div>

        <!-- ── Columna derecha: formulario ── -->
        <div id="reservar" class="lg:col-span-2 scroll-mt-24">
          <div class="lg:sticky lg:top-6">
            <div class="overflow-hidden" style="border: 2px solid #0A0E0B; box-shadow: 6px 6px 0 #0FCB46">

              <!-- Header del form -->
              <div style="background: #0A0E0B; padding: 20px 24px">
                <span style="font: 600 10px/1 'JetBrains Mono', monospace; letter-spacing: .15em; text-transform: uppercase; color: rgba(244,245,240,.5)">
                  Reservar cancha
                </span>
                <div class="mt-2" style="font: 900 36px/1 'Archivo', system-ui; color: #0FCB46; font-variant-numeric: tabular-nums">
                  S/{court.pricePerHour}
                  <span style="font: 500 14px/1 'Inter', sans-serif; color: rgba(244,245,240,.5)">/hora</span>
                </div>
              </div>

              <!-- ReservationForm -->
              <div class="bg-white" style="padding: 20px 24px">
                <ReservationForm court={court} apiUrl={API_URL} client:load />
              </div>

            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- ── STICKY CTA MÓVIL ────────────────────────────────────── -->
  <div
    class="lg:hidden fixed bottom-0 inset-x-0 z-40 flex items-center justify-between gap-4 px-4 py-3"
    style="background: #0A0E0B; border-top: 2px solid #0FCB46"
  >
    <div class="min-w-0">
      <div style="font: 600 9px/1 'JetBrains Mono', monospace; letter-spacing: .1em; text-transform: uppercase; color: rgba(244,245,240,.5)">
        Desde
      </div>
      <div style="font: 900 24px/1 'Archivo', system-ui; color: #0FCB46; margin-top: 3px; font-variant-numeric: tabular-nums">
        S/{court.pricePerHour}
        <span style="font: 500 12px/1 'Inter', sans-serif; color: rgba(244,245,240,.4)">/hora</span>
      </div>
    </div>
    <a
      href="#reservar"
      style="background: #0FCB46; color: #0A0E0B; border: 2px solid #F4F5F0; padding: 12px 20px; font: 800 13px/1 'Archivo', system-ui; letter-spacing: .01em; text-transform: uppercase; text-decoration: none; white-space: nowrap; box-shadow: 3px 3px 0 rgba(244,245,240,.25)"
    >
      Reservar ahora →
    </a>
  </div>

</Layout>

<style is:global>
  .court-description strong { font-weight: 600; color: #0A0E0B; }
  .court-description em { font-style: italic; }
  .court-description p { margin-bottom: 0.375rem; font-family: 'Inter', sans-serif; }
  .court-description p:last-child { margin-bottom: 0; }
  .court-description ul { list-style-type: disc; padding-left: 1.25rem; margin-bottom: 0.375rem; }
  .court-description ol { list-style-type: decimal; padding-left: 1.25rem; margin-bottom: 0.375rem; }
  .court-description li { margin-bottom: 0.125rem; }
</style>

<script>
  const slides = document.querySelectorAll<HTMLElement>('.gallery-slide');
  const dots = document.querySelectorAll<HTMLElement>('.gallery-dot');
  const counter = document.getElementById('gallery-current');
  let current = 0;

  function goTo(index: number) {
    slides[current].style.opacity = '0';
    slides[current].style.zIndex = '0';
    if (dots[current]) dots[current].style.cssText = 'width: 8px; height: 4px; background: rgba(244,245,240,.4)';

    current = (index + slides.length) % slides.length;

    slides[current].style.opacity = '1';
    slides[current].style.zIndex = '1';
    if (dots[current]) dots[current].style.cssText = 'width: 24px; height: 4px; background: #0FCB46';
    if (counter) counter.textContent = String(current + 1);
  }

  document.getElementById('gallery-prev')?.addEventListener('click', () => goTo(current - 1));
  document.getElementById('gallery-next')?.addEventListener('click', () => goTo(current + 1));
  dots.forEach((dot) => {
    dot.addEventListener('click', () => goTo(Number(dot.dataset.target)));
  });

  if (slides.length > 1) {
    setInterval(() => goTo(current + 1), 5000);
  }
</script>
