---
import Layout from '../../layouts/Layout.astro';
import MyReservations from '../../components/MyReservations';

const API_URL = import.meta.env.PUBLIC_API_URL;
---

<Layout title="Mis Reservas – Micancha">
  <div class="max-w-2xl mx-auto px-4 py-12">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900">Mis reservas</h1>
      <p class="text-gray-500 mt-1">Consulta el estado de tus reservas y accede a tus códigos QR.</p>
    </div>
    <MyReservations apiUrl={API_URL} client:load />
  </div>
</Layout>
