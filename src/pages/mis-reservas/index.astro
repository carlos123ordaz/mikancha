---
import Layout from '../../layouts/Layout.astro';
import MyReservations from '../../components/MyReservations';

const API_URL = import.meta.env.PUBLIC_API_URL;
---

<Layout title="Mis Reservas" description="Consulta el estado de tus reservas y accede a tu código QR">

  <!-- ── HEADER ─────────────────────────────────────────────── -->
  <section
    class="relative bg-mk-dark text-mk-cream overflow-hidden"
    style="padding: 48px 48px 52px; border-bottom: 4px solid #0FCB46"
  >
    <div class="absolute inset-0 pointer-events-none" style="background-image: linear-gradient(0deg, rgba(15,203,70,.06) 1px, transparent 1px); background-size: 100% 80px"></div>

    <div class="relative max-w-3xl mx-auto">
      <div class="header-content flex flex-col gap-4">
        <span class="inline-flex items-center gap-2" style="font: 600 11px/1 'JetBrains Mono', monospace; letter-spacing: .15em; text-transform: uppercase; color: #0FCB46">
          <span style="width: 16px; height: 1.5px; background: #0FCB46; display: inline-block"></span>
          Historial personal
        </span>
        <h1 style="margin: 0; font: 900 clamp(36px, 6vw, 64px)/0.9 'Archivo', system-ui; letter-spacing: -.03em">
          Mis reservas.<br />
          <span style="color: #0FCB46">Tu historial.</span>
        </h1>
        <p style="margin: 0; max-width: 440px; font: 400 15px/1.55 'Inter', sans-serif; color: rgba(244,245,240,.7)">
          Consulta el estado de tus reservas y accede a tu código QR al instante.
        </p>
        <div class="flex flex-wrap gap-2" style="margin-top: 4px">
          {[
            { color: '#FFE249',           label: 'Pendientes' },
            { color: '#0FCB46',           label: 'Aprobadas'  },
            { color: 'rgba(255,80,80,.8)',label: 'Rechazadas' },
          ].map(({ color, label }) => (
            <span style={`display: inline-flex; align-items: center; gap: 6px; padding: 5px 10px; background: rgba(244,245,240,.07); border: 1px solid rgba(244,245,240,.12); font: 600 10px/1 'JetBrains Mono', monospace; letter-spacing: .1em; text-transform: uppercase; color: rgba(244,245,240,.7)`}>
              <span style={`width: 6px; height: 6px; background: ${color}; display: inline-block; flex-shrink: 0`}></span>
              {label}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── CONTENT ─────────────────────────────────────────────── -->
  <section class="bg-mk-cream" style="padding: 48px 48px 80px">
    <div style="max-width: 720px; margin: 0 auto">
      <MyReservations apiUrl={API_URL} client:load />
    </div>
  </section>

</Layout>

<style>
  .header-content {
    animation: fadeUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.1s both;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
