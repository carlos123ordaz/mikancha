---
import Layout from '../../layouts/Layout.astro';
import MyReservations from '../../components/MyReservations';

const API_URL = import.meta.env.PUBLIC_API_URL;
---

<Layout title="Mis Reservas" description="Consulta el estado de tus reservas y accede a tu código QR">

  <!-- ── HERO ─────────────────────────────────────────────── -->
  <section class="relative overflow-hidden bg-gray-950">
    <div class="absolute inset-0">
      <img
        src="/img1.webp"
        alt="Cancha deportiva"
        class="w-full h-full object-cover"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-gray-950/75 via-gray-950/55 to-gray-950/90"></div>
    </div>

    <!-- Decorative blobs -->
    <div class="absolute -top-24 -left-24 w-96 h-96 bg-primary-500/20 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-24 -right-24 w-96 h-96 bg-emerald-300/10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative z-10 max-w-5xl mx-auto px-4 py-16 sm:py-20 lg:py-24 text-center">
      <div class="hero-badge inline-flex items-center gap-2 bg-white/10 backdrop-blur-md border border-white/20 rounded-full px-4 py-1.5 mb-6">
        <span class="w-2 h-2 rounded-full bg-primary-400 animate-pulse"></span>
        <span class="text-white/90 text-xs sm:text-sm font-medium tracking-wide">
          Historial personal
        </span>
      </div>

      <h1 class="hero-title font-heading text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-[1.05] mb-4">
        Mis
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-400 to-emerald-300">
          reservas
        </span>
      </h1>

      <p class="hero-sub text-base sm:text-lg text-white/75 max-w-2xl mx-auto mb-7 font-light">
        Consulta el estado de tus reservas y accede a tu código QR al instante.
      </p>

      <div class="hero-chips flex flex-wrap items-center justify-center gap-2 sm:gap-3">
        <span class="inline-flex items-center gap-1.5 bg-white/10 backdrop-blur-md border border-white/15 rounded-full px-3 py-1.5 text-white/85 text-xs sm:text-sm">
          <span>⏳</span> Pendientes
        </span>
        <span class="inline-flex items-center gap-1.5 bg-white/10 backdrop-blur-md border border-white/15 rounded-full px-3 py-1.5 text-white/85 text-xs sm:text-sm">
          <span>✅</span> Aprobadas
        </span>
        <span class="inline-flex items-center gap-1.5 bg-white/10 backdrop-blur-md border border-white/15 rounded-full px-3 py-1.5 text-white/85 text-xs sm:text-sm">
          <span>📲</span> QR disponible
        </span>
      </div>
    </div>

    <!-- Wave divider -->
    <svg class="absolute bottom-0 left-0 w-full h-10 sm:h-14 text-gray-50" viewBox="0 0 1440 60" preserveAspectRatio="none" aria-hidden="true">
      <path fill="currentColor" d="M0,32 C240,64 480,0 720,16 C960,32 1200,64 1440,32 L1440,60 L0,60 Z"/>
    </svg>
  </section>

  <!-- ── CONTENIDO ────────────────────────────────────────── -->
  <section class="max-w-3xl mx-auto px-4 py-10 sm:py-14">
    <MyReservations apiUrl={API_URL} client:load />
  </section>

</Layout>

<style>
  .hero-badge { animation: fadeDown 0.6s cubic-bezier(0.22, 1, 0.36, 1) 0.05s both; }
  .hero-title { animation: fadeUp   0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.2s  both; }
  .hero-sub   { animation: fadeUp   0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.35s both; }
  .hero-chips { animation: fadeUp   0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.5s  both; }

  @keyframes fadeUp   { from { opacity: 0; transform: translateY(28px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes fadeDown { from { opacity: 0; transform: translateY(-14px); } to { opacity: 1; transform: translateY(0); } }
</style>
