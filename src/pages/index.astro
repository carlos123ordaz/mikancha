---
import Layout from '../layouts/Layout.astro';
import type { ICourt } from '../types';

const API_URL = import.meta.env.PUBLIC_API_URL;

let featuredCourts: ICourt[] = [];
try {
  const res = await fetch(`${API_URL}/api/courts`);
  const json = await res.json();
  if (json.success) featuredCourts = (json.data ?? []).slice(0, 3);
} catch {
  // silently degrade
}
---

<Layout title="Inicio">

  <!-- ── HERO · Scoreboard ────────────────────────────────────── -->
  <section
    class="relative bg-mk-dark text-mk-cream overflow-hidden"
    style="padding: 48px 48px 80px; border-bottom: 4px solid #0FCB46"
  >
    <!-- Field lines pattern -->
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: linear-gradient(0deg, rgba(15,203,70,.06) 1px, transparent 1px); background-size: 100% 80px"
    ></div>

    <!-- Asymmetric grid: left content + right scoreboard -->
    <div class="relative max-w-7xl mx-auto mt-10 grid grid-cols-1 lg:grid-cols-[1.4fr_1fr] gap-12 items-end">

      <!-- Left: Heading -->
      <div class="hero-left">
        <span
          class="inline-flex items-center gap-2 mb-6"
          style="font: 600 11px/1 'JetBrains Mono', monospace; letter-spacing: .15em; text-transform: uppercase; color: #0FCB46"
        >
          <span class="inline-block w-5" style="height: 1.5px; background: #0FCB46"></span>
          Reserva en 60 segundos · Lima, Perú
        </span>

        <h1
          class="hero-title"
          style="margin: 0; font: 900 clamp(56px, 9vw, 118px)/0.88 'Archivo', system-ui; letter-spacing: -.035em; text-wrap: balance"
        >
          Tu cancha.<br />
          <span style="color: #0FCB46">Tu hora.</span><br />
          <span
            class="inline-block"
            style="background: #FFE249; color: #0A0E0B; padding: 0 18px; margin-top: 8px; transform: rotate(-1deg)"
          >
            Tu pichanga.
          </span>
        </h1>

        <p
          class="hero-sub"
          style="margin: 32px 0 0; max-width: 480px; font: 400 17px/1.55 'Inter', sans-serif; color: rgba(244,245,240,.72)"
        >
          Reserva canchas de fútbol, vóley, básquet, tenis y pádel en los mejores distritos de Lima. Yape, transfiere y a jugar.
        </p>

        <!-- Mobile CTA (hidden on lg) -->
        <div class="mt-8 lg:hidden">
          <a
            href="/canchas"
            class="inline-flex items-center gap-2 bg-mk-green text-mk-dark font-heading font-black text-sm px-6 py-4"
            style="border: 2px solid #F4F5F0; box-shadow: 4px 4px 0 #F4F5F0; letter-spacing: .02em; text-transform: uppercase"
          >
            Ver canchas disponibles →
          </a>
        </div>
      </div>

      <!-- Right: Scoreboard panel (hidden on mobile) -->
      <div
        class="hero-panel hidden lg:flex flex-col gap-4"
        style="background: #111512; border: 1.5px solid rgba(244,245,240,.12); padding: 24px"
      >
        <!-- Panel header -->
        <div
          class="flex justify-between items-center pb-3"
          style="border-bottom: 1px solid rgba(244,245,240,.1)"
        >
          <span style="font: 600 10px/1 'JetBrains Mono', monospace; letter-spacing: .15em; text-transform: uppercase; color: rgba(244,245,240,.5)">
            ● LIVE · MIKANCHA SCOREBOARD
          </span>
          <span style="font: 600 10px/1 'JetBrains Mono', monospace; color: #0FCB46">HOY</span>
        </div>

        <!-- Stats 2x2 grid -->
        <div class="grid grid-cols-2" style="border: 1px solid rgba(244,245,240,.1)">
          {[
            { label: 'Canchas',      value: '10+',  accent: '#0FCB46' },
            { label: 'Distritos',    value: '5',    accent: '#FFE249' },
            { label: 'Reservas hoy', value: '500+', accent: '#FFE249' },
            { label: 'Disponibles',  value: '89%',  accent: '#0FCB46' },
          ].map(({ label, value, accent }) => (
            <div style={`padding: 10px 14px; border-left: 2px solid ${accent}`}>
              <div style="font: 500 9.5px/1 'JetBrains Mono', monospace; letter-spacing: .1em; text-transform: uppercase; color: rgba(244,245,240,.55); margin-bottom: 5px">
                {label}
              </div>
              <div style="font: 800 22px/1 'Archivo', system-ui; color: #F4F5F0; font-variant-numeric: tabular-nums">
                {value}
              </div>
            </div>
          ))}
        </div>

        <!-- Search form -->
        <div style="background: #0A0E0B; border: 1px solid rgba(15,203,70,.3); padding: 16px; display: flex; flex-direction: column; gap: 10px">
          <label style="font: 600 10px/1 'JetBrains Mono', monospace; letter-spacing: .12em; text-transform: uppercase; color: #0FCB46">
            ▮ Buscar por distrito
          </label>
          <form action="/canchas" method="get" class="flex gap-2">
            <input
              name="q"
              placeholder="Miraflores, Surco..."
              class="flex-1"
              style="height: 44px; padding: 0 12px; background: transparent; border: 1.5px solid rgba(244,245,240,.2); color: #F4F5F0; font: 500 14px/1 'Inter', sans-serif; outline: none"
            />
            <button
              type="submit"
              style="padding: 0 18px; height: 44px; background: #0FCB46; color: #0A0E0B; border: 2px solid #0A0E0B; font: 700 12px/1 'Inter', sans-serif; letter-spacing: .01em; text-transform: uppercase; box-shadow: 3px 3px 0 rgba(244,245,240,.2); cursor: pointer; white-space: nowrap; transition: transform .1s ease, box-shadow .1s ease"
              onmousedown="this.style.transform='translate(1px,1px)';this.style.boxShadow='1px 1px 0 rgba(244,245,240,.2)'"
              onmouseup="this.style.transform='';this.style.boxShadow='3px 3px 0 rgba(244,245,240,.2)'"
              onmouseleave="this.style.transform='';this.style.boxShadow='3px 3px 0 rgba(244,245,240,.2)'"
            >
              Buscar →
            </button>
          </form>
        </div>
      </div>

    </div>
  </section>

  <!-- ── FEATURES STRIP ───────────────────────────────────────── -->
  <section
    class="bg-mk-green text-mk-dark"
    style="padding: 32px 48px; border-top: 3px solid #0A0E0B; border-bottom: 3px solid #0A0E0B"
  >
    <div class="max-w-7xl mx-auto flex flex-wrap justify-around items-center gap-6">
      {[
        { num: '10+',  label: 'Canchas activas' },
        { num: '500+', label: 'Reservas realizadas' },
        { num: '60s',  label: 'Tiempo de reserva' },
        { num: '4.9★', label: 'Calificación promedio' },
      ].map(({ num, label }) => (
        <div class="flex items-center gap-4">
          <span style="font: 900 44px/1 'Archivo', system-ui; letter-spacing: -.03em; font-variant-numeric: tabular-nums">
            {num}
          </span>
          <span style="font: 600 12px/1.3 'JetBrains Mono', monospace; letter-spacing: .08em; text-transform: uppercase; max-width: 130px">
            {label}
          </span>
        </div>
      ))}
    </div>
  </section>

  <!-- ── CANCHAS DESTACADAS ────────────────────────────────────── -->
  {featuredCourts.length > 0 && (
    <section class="bg-mk-cream" style="padding: 80px 48px">
      <div class="max-w-7xl mx-auto">

        <!-- Section head -->
        <div class="flex flex-col gap-3 max-w-2xl mb-12">
          <span
            class="inline-flex items-center gap-2"
            style="font: 600 11px/1 'JetBrains Mono', monospace; letter-spacing: .15em; text-transform: uppercase; color: #0A0E0B"
          >
            <span class="inline-block w-4" style="height: 1.5px; background: #0A0E0B"></span>
            01 · Canchas destacadas
          </span>
          <h2 style="margin: 0; font: 800 clamp(32px, 4.5vw, 52px)/0.95 'Archivo', system-ui; letter-spacing: -.02em; color: #0A0E0B">
            Filtra. Elige. Reserva.
          </h2>
          <p style="margin: 0; font: 400 16px/1.5 'Inter', sans-serif; color: rgba(10,14,11,.65); max-width: 480px">
            Elige la que más te guste y reserva hoy mismo.
          </p>
        </div>

        <!-- Cards grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredCourts.map((court) => (
            <a
              href={`/canchas/${court._id}`}
              class="group bg-white flex flex-col transition-all duration-150"
              style="border: 2px solid #0A0E0B; text-decoration: none"
              onmouseenter="this.style.transform='translate(-2px,-2px)';this.style.boxShadow='6px 6px 0 #0FCB46'"
              onmouseleave="this.style.transform='';this.style.boxShadow=''"
            >
              {court.images?.[0] ? (
                <div class="overflow-hidden relative" style="height: 180px">
                  <img
                    src={court.images[0]}
                    alt={court.name}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                  <div
                    class="absolute top-2 right-2"
                    style="background: #FFE249; color: #0A0E0B; border: 1.5px solid #0A0E0B; padding: 5px 10px; font: 700 10px/1 'JetBrains Mono', monospace; letter-spacing: .08em; text-transform: uppercase"
                  >
                    Fútbol
                  </div>
                </div>
              ) : (
                <div class="relative overflow-hidden flex items-end justify-start" style="height: 180px; background: #0A0E0B">
                  <div
                    class="absolute inset-0"
                    style="background: repeating-linear-gradient(135deg, #0A2A14 0 14px, #0D341A 14px 28px)"
                  ></div>
                  <div
                    class="absolute"
                    style="top: 50%; left: 8%; right: 8%; height: 2px; background: rgba(255,255,255,.18); transform: translateY(-50%)"
                  ></div>
                  <div
                    class="absolute"
                    style="top: 50%; left: 50%; width: 56px; height: 56px; border: 2px solid rgba(255,255,255,.2); border-radius: 50%; transform: translate(-50%, -50%)"
                  ></div>
                  <span
                    class="relative z-10 p-3"
                    style="font: 600 9.5px/1 'JetBrains Mono', monospace; letter-spacing: .08em; text-transform: uppercase; color: #0FCB46"
                  >
                    ▮ LIBRE HOY
                  </span>
                </div>
              )}

              <div class="flex flex-col gap-3 flex-1" style="padding: 18px">
                <div>
                  <div style="font: 600 10px/1 'JetBrains Mono', monospace; letter-spacing: .1em; text-transform: uppercase; color: rgba(10,14,11,.55); margin-bottom: 6px">
                    ◉ {court.location}
                  </div>
                  <h3 style="margin: 0; font: 800 18px/1.15 'Archivo', system-ui; letter-spacing: -.01em; color: #0A0E0B">
                    {court.name}
                  </h3>
                </div>

                <div class="mt-auto flex items-center justify-between" style="padding-top: 14px; border-top: 1px dashed rgba(10,14,11,.2)">
                  <div>
                    <div style="font: 600 9px/1 'JetBrains Mono', monospace; letter-spacing: .1em; text-transform: uppercase; color: rgba(10,14,11,.5); margin-bottom: 3px">
                      desde
                    </div>
                    <div style="font: 900 24px/1 'Archivo', system-ui; font-variant-numeric: tabular-nums; color: #0A0E0B">
                      S/{court.pricePerHour}
                      <span style="font: 500 12px/1 'Inter', sans-serif; color: rgba(10,14,11,.55); margin-left: 4px">/h</span>
                    </div>
                  </div>
                  <span style="font: 700 12px/1 'Inter', sans-serif; color: #0FCB46; display: inline-flex; align-items: center; gap: 4px">
                    Reservar →
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>

        <!-- CTA link -->
        <div class="mt-10">
          <a
            href="/canchas"
            class="inline-flex items-center gap-3 text-mk-cream font-heading font-black text-sm"
            style="background: #0A0E0B; border: 2px solid #0A0E0B; padding: 16px 24px; letter-spacing: .02em; text-transform: uppercase; box-shadow: 4px 4px 0 #0FCB46; text-decoration: none; transition: transform .1s ease, box-shadow .1s ease"
            onmousedown="this.style.transform='translate(2px,2px)';this.style.boxShadow='2px 2px 0 #0FCB46'"
            onmouseup="this.style.transform='';this.style.boxShadow='4px 4px 0 #0FCB46'"
            onmouseleave="this.style.transform='';this.style.boxShadow='4px 4px 0 #0FCB46'"
          >
            Ver todas las canchas →
          </a>
        </div>

      </div>
    </section>
  )}

  <!-- ── CÓMO FUNCIONA ─────────────────────────────────────────── -->
  <section
    class="bg-mk-dark text-mk-cream"
    style="padding: 100px 48px"
    id="como-funciona"
  >
    <div class="max-w-7xl mx-auto">

      <!-- Section head -->
      <div class="flex flex-col gap-3 max-w-2xl mb-14">
        <span
          class="inline-flex items-center gap-2"
          style="font: 600 11px/1 'JetBrains Mono', monospace; letter-spacing: .15em; text-transform: uppercase; color: #0FCB46"
        >
          <span class="inline-block w-4" style="height: 1.5px; background: #0FCB46"></span>
          02 · Cómo funciona
        </span>
        <h2 style="margin: 0; font: 800 clamp(32px, 4.5vw, 52px)/0.95 'Archivo', system-ui; letter-spacing: -.02em; color: #F4F5F0">
          Reservar nunca fue tan fácil.
        </h2>
        <p style="margin: 0; font: 400 16px/1.5 'Inter', sans-serif; color: rgba(244,245,240,.7); max-width: 520px">
          Sin llamadas, sin esperar respuesta del dueño. Todo desde la app en minutos.
        </p>
      </div>

      <!-- Steps grid -->
      <div
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4"
        style="border: 1.5px solid rgba(244,245,240,.15)"
      >
        {[
          { n: '01', title: 'Encuentra tu cancha',  desc: 'Filtra por distrito y horario. Disponibilidad en vivo entre cientos de canchas.' },
          { n: '02', title: 'Elige fecha y hora',    desc: 'Calendario en vivo. Slots disponibles y ocupados al toque, sin sorpresas.' },
          { n: '03', title: 'Yapea o transfiere',    desc: 'Paga con Yape, Plin o cuenta bancaria. Sube tu comprobante en segundos.' },
          { n: '04', title: 'A jugar',               desc: 'Recibes confirmación por WhatsApp. Llegas, juegas, te vas. Listo.' },
        ].map(({ n, title, desc }, i) => (
          <div
            class="flex flex-col gap-3"
            style={`padding: 28px 24px${i < 3 ? '; border-right: 1.5px solid rgba(244,245,240,.15)' : ''}`}
          >
            <div style="font: 900 56px/1 'Archivo', system-ui; color: #0FCB46; letter-spacing: -.03em">
              {n}
            </div>
            <h3 style="margin: 0; font: 800 20px/1.15 'Archivo', system-ui; letter-spacing: -.01em; color: #F4F5F0">
              {title}
            </h3>
            <p style="margin: 0; font: 400 13px/1.5 'Inter', sans-serif; color: rgba(244,245,240,.65)">
              {desc}
            </p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ── CTA FINAL ─────────────────────────────────────────────── -->
  <section
    class="bg-mk-green text-mk-dark text-center"
    style="padding: 80px 48px; border-top: 3px solid #0A0E0B"
  >
    <div class="max-w-3xl mx-auto">
      <h2 style="margin: 0 0 16px; font: 900 clamp(40px, 6vw, 72px)/0.9 'Archivo', system-ui; letter-spacing: -.03em">
        ¿Listo para jugar?
      </h2>
      <p style="margin: 0 0 40px; font: 400 18px/1.5 'Inter', sans-serif; color: rgba(10,14,11,.72)">
        Ingresa con tu cuenta y realiza tu primera reserva en 60 segundos.
      </p>
      <a
        href="/canchas"
        class="inline-flex items-center gap-3 text-mk-cream font-heading font-black"
        style="background: #0A0E0B; border: 2px solid #0A0E0B; padding: 18px 40px; font: 800 16px/1 'Archivo', system-ui; letter-spacing: .01em; text-transform: uppercase; box-shadow: 6px 6px 0 #0A0E0B; text-decoration: none; transition: transform .1s ease, box-shadow .1s ease"
        onmousedown="this.style.transform='translate(3px,3px)';this.style.boxShadow='3px 3px 0 #0A0E0B'"
        onmouseup="this.style.transform='';this.style.boxShadow='6px 6px 0 #0A0E0B'"
        onmouseleave="this.style.transform='';this.style.boxShadow='6px 6px 0 #0A0E0B'"
      >
        Ver canchas disponibles
      </a>
    </div>
  </section>

</Layout>

<style>
  /* Hero entrance animations */
  .hero-left {
    animation: fadeUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.1s both;
  }
  .hero-title {
    animation: fadeUp 0.75s cubic-bezier(0.22, 1, 0.36, 1) 0.25s both;
  }
  .hero-sub {
    animation: fadeUp 0.75s cubic-bezier(0.22, 1, 0.36, 1) 0.4s both;
  }
  .hero-panel {
    animation: fadeUp 0.75s cubic-bezier(0.22, 1, 0.36, 1) 0.35s both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Step borders collapse on mobile */
  @media (max-width: 1023px) {
    .grid > div[style*="border-right"] {
      border-right: none !important;
      border-bottom: 1.5px solid rgba(244, 245, 240, 0.15);
    }
  }
</style>
