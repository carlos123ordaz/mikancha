---
import Navbar from '../components/Navbar.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Reserva tu cancha deportiva fácilmente' } = Astro.props;
const year = new Date().getFullYear();
const WHATSAPP_NUMBER = import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? '51913628087';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const showWhatsAppFab = pathname === '/' || pathname === '/canchas';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0FCB46" />
    <link rel="icon" type="image/x-icon" href="/icono.ico" />
    <link rel="shortcut icon" href="/icono.ico" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,400;0,700;0,800;0,900;1,800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title} | MiKancha</title>
  </head>
  <body class="min-h-screen bg-mk-cream text-mk-dark antialiased">
    <Navbar />
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer style="background: #0A0E0B; color: #F4F5F0; border-top: 3px solid #0FCB46;">
      <div class="max-w-7xl mx-auto px-6 lg:px-12 py-14 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12">

        <!-- Brand -->
        <div>
          <div class="flex items-center gap-3 mb-5">
            <div
              class="w-9 h-9 bg-mk-green flex items-center justify-center font-heading font-black text-lg text-mk-dark border-2 border-mk-cream"
              style="transform: rotate(-3deg); line-height: 1"
            >M</div>
            <span class="font-heading font-black text-xl text-mk-cream" style="letter-spacing: -.02em">
              MIKANCHA<span class="text-mk-green">.</span>
            </span>
          </div>
          <p style="font: 400 13px/1.6 'Inter', sans-serif; color: rgba(244,245,240,0.6); max-width: 280px">
            La forma más fácil de reservar canchas deportivas en Lima. Hecho con amor en Perú.
          </p>
        </div>

        <!-- Plataforma -->
        <div>
          <div class="mb-4" style="font: 600 10px/1 'JetBrains Mono', monospace; letter-spacing: .15em; text-transform: uppercase; color: #0FCB46">
            Plataforma
          </div>
          <ul class="flex flex-col gap-3" style="list-style: none; margin: 0; padding: 0">
            {[
              { href: '/canchas',           label: 'Buscar canchas' },
              { href: '/#como-funciona',    label: 'Cómo funciona' },
              { href: '/publica-tu-cancha', label: 'Para dueños' },
              { href: '/mis-reservas',      label: 'Mis reservas' },
            ].map(({ href, label }) => (
              <li>
                <a href={href} style="font: 500 13px/1 'Inter', sans-serif; color: rgba(244,245,240,0.75); text-decoration: none" class="hover:text-mk-cream transition-colors">
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Soporte -->
        <div>
          <div class="mb-4" style="font: 600 10px/1 'JetBrains Mono', monospace; letter-spacing: .15em; text-transform: uppercase; color: #0FCB46">
            Soporte
          </div>
          <ul class="flex flex-col gap-3" style="list-style: none; margin: 0; padding: 0">
            <li>
              <a
                href={`https://wa.me/${WHATSAPP_NUMBER}`}
                target="_blank"
                rel="noopener noreferrer"
                style="font: 500 13px/1 'Inter', sans-serif; color: rgba(244,245,240,0.75); text-decoration: none"
                class="hover:text-mk-cream transition-colors"
              >
                WhatsApp
              </a>
            </li>
            {['Centro de ayuda', 'Términos', 'Privacidad'].map((item) => (
              <li>
                <span style="font: 500 13px/1 'Inter', sans-serif; color: rgba(244,245,240,0.4)">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Síguenos -->
        <div>
          <div class="mb-4" style="font: 600 10px/1 'JetBrains Mono', monospace; letter-spacing: .15em; text-transform: uppercase; color: #0FCB46">
            Síguenos
          </div>
          <ul class="flex flex-col gap-3" style="list-style: none; margin: 0; padding: 0">
            {['Instagram', 'TikTok', 'Facebook', 'YouTube'].map((item) => (
              <li>
                <span style="font: 500 13px/1 'Inter', sans-serif; color: rgba(244,245,240,0.75); cursor: pointer">{item}</span>
              </li>
            ))}
          </ul>
        </div>

      </div>

      <!-- Bottom bar -->
      <div style="border-top: 1px solid rgba(244,245,240,0.1)">
        <div
          class="max-w-7xl mx-auto px-6 lg:px-12 py-5 flex flex-col sm:flex-row items-center justify-between gap-3"
          style="font: 500 11px/1 'JetBrains Mono', monospace; letter-spacing: .05em; color: rgba(244,245,240,0.4)"
        >
          <span>© {year} MiKancha SAC · Lima, Perú</span>
          <span>HECHO PARA LA PICHANGA ▮</span>
        </div>
      </div>
    </footer>

    {showWhatsAppFab && <WhatsAppButton />}
  </body>
</html>
